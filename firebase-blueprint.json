{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product for sale in the store.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "price": { "type": "number", "description": "Current price" },
        "originalPrice": { "type": "number", "description": "Original price for comparison" },
        "description": { "type": "string", "description": "Short description" },
        "fullDescription": { "type": "string", "description": "Exhaustive description of benefits" },
        "imageUrl": { "type": "string", "description": "URL of the product image" },
        "whatsappText": { "type": "string", "description": "Custom text for WhatsApp conversion" },
        "isKit": { "type": "boolean", "description": "Whether this is a kit of multiple units" },
        "kitUnits": { "type": "number", "description": "Number of units in the kit" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "imageUrl"]
    },
    "Setting": {
      "title": "Store Setting",
      "description": "General configurations for the site.",
      "type": "object",
      "properties": {
        "storeName": { "type": "string" },
        "whatsapp": { "type": "string" },
        "instagram": { "type": "string" },
        "facebook": { "type": "string" },
        "tiktok": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "sacEmail": { "type": "string" },
        "sacPhone": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Individual product documents"
    },
    "/settings/general": {
      "schema": "Setting",
      "description": "Global site settings"
    }
  }
}
